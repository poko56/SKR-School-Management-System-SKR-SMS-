rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helpers
    function isAuthenticated() {
      return request.auth != null;
    }
    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.role == 'super_admin';
    }
    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == 'admin';
    }
    function isHeadStudent() {
      return isAuthenticated() && request.auth.token.role == 'head_student';
    }

    // Default Rule: Deny all reads and writes unless overridden below
    match /{document=**} {
      allow write: if false; // ล็อกการเขียนจากหน้าบ้านทั้งหมด 100%
      allow read: if false;
    }

    // 1. General Data (อ่านได้ทุกคนที่ล็อคอินเข้าสู่ระบบ)
    match /announcements/{docId} {
      allow read: if isAuthenticated();
    }
    match /attendance/{docId} {
      allow read: if isAuthenticated();
    }
    match /settings/{docId} {
      allow read: if isAuthenticated();
    }
    match /rooms/{docId} {
      allow read: if isAuthenticated(); // ทุกคนที่ Login อ่านได้ (สำหรับ Dropdown เลือกห้อง)
    }
    
    // 2. Sensitive Admins Data (เฉพาะ Super Admin และ Admin)
    match /system_logs/{docId} {
      allow read: if isSuperAdmin() || isAdmin();
    }
    match /edit_requests/{docId} {
      allow read: if isSuperAdmin() || isAdmin();
    }

    // 3. User Accounts (จัดการผู้ใช้ ให้อ่านได้ตามสิทธิ์ชั้นการปกครอง)
    match /users/{userId} {
      allow read: if isSuperAdmin() || isAdmin() || isHeadStudent() || request.auth.uid == userId;
    }
  }
}